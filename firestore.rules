rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, email, displayName, role, phoneNumber, dateOfBirth, idType, idNumber, balance, loyaltyPoints, createdAt
    //
    // Collection: draws
    // Fields: type, date, numbers, jackpot, status, createdAt
    //
    // Collection: tickets
    // Fields: userId, agentId, drawType, numbers, individualAmounts, amount, status, type, createdAt
    //
    // Collection: transactions
    // Fields: userId, amount, type, method, status, createdAt
    //
    // Collection: branches
    // Fields: name, location, managerId, createdAt
    //
    // Collection: otps
    // Fields: userId, code, type, status, expiresAt, createdAt
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "jeanbernardpierrelouis@gmail.com" && request.auth.token.email_verified == true));
    }

    function isAgent() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'agent';
    }

    function isSupervisor() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'supervisor';
    }

    // Validation Functions
    function isValidUser(data) {
      return data.uid is string && 
             (data.email == null || data.email is string) && 
             data.role in ['client', 'agent', 'supervisor', 'branch', 'admin'] &&
             (data.phoneNumber == null || data.phoneNumber is string) &&
             (data.balance == null || data.balance is number) &&
             (data.dateOfBirth == null || data.dateOfBirth is string) &&
             (data.idType == null || data.idType in ['CIN', 'NIF', 'Passport']) &&
             (data.idNumber == null || data.idNumber is string);
    }

    function isValidDraw(data) {
      return data.type in ['New York', 'Florida', 'Georgia', 'Lotto 3', 'Lotto 4', 'Lotto 5'] && 
             data.numbers is list && 
             data.jackpot is number;
    }

    function isValidTicket(data) {
      return data.userId is string && 
             data.drawType is string && 
             data.numbers is list && 
             (data.individualAmounts == null || data.individualAmounts is list) &&
             data.amount is number &&
             data.amount > 0;
    }

    // Rules
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin() || isSupervisor();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(uid) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(uid) || isAdmin() || isSupervisor()) && 
                    (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /draws/{drawId} {
      allow read: if true; // Publicly readable
      allow create, update, delete: if isAdmin() || isSupervisor();
    }

    match /tickets/{ticketId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin() || isAgent() || isSupervisor());
      allow create: if isAuthenticated() && isValidTicket(request.resource.data) && (request.auth.uid == request.resource.data.userId || isAgent() || isAdmin());
      allow update: if isAdmin() || isAgent() || isSupervisor();
    }

    match /transactions/{txId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin() || isSupervisor());
      allow create: if isAuthenticated() && (request.auth.uid == request.resource.data.userId || isAdmin());
      allow update: if isAdmin() || isSupervisor();
    }

    match /branches/{branchId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() || isSupervisor();
    }

    match /otps/{otpId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow update: if isAuthenticated() && request.auth.uid == resource.data.userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
    }
  }
}
